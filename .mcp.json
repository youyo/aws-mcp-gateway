{
  "mcpServers": {
    "aws-direct": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-northeast-1"
      ],
      "env": {
        "AWS_PROFILE": "sandbox-ishizawa"
      }
    }
  }
}
