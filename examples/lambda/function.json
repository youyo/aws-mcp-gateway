{
  "FunctionName": "{{ must_env `INSTANCE_NAME` }}",
  "Description": "OIDC-authenticated reverse proxy for AWS MCP Server",
  "Runtime": "provided.al2023",
  "Handler": "bootstrap",
  "Architectures": ["arm64"],
  "MemorySize": 256,
  "Timeout": 900,
  "Role": "{{ must_env `ROLE_ARN` }}",
  "Layers": [
    "arn:aws:lambda:{{ must_env `AWS_REGION` }}:753240598075:layer:LambdaAdapterLayerArm64:27"
  ],
  "Environment": {
    "Variables": {
      "EXTERNAL_URL":        "{{ ssm (printf `/%s/EXTERNAL_URL`       (must_env `INSTANCE_NAME`)) }}",
      "OIDC_ISSUER":         "{{ ssm (printf `/%s/OIDC_ISSUER`        (must_env `INSTANCE_NAME`)) }}",
      "OIDC_CLIENT_ID":      "{{ ssm (printf `/%s/OIDC_CLIENT_ID`     (must_env `INSTANCE_NAME`)) }}",
      "OIDC_CLIENT_SECRET":  "{{ ssm (printf `/%s/OIDC_CLIENT_SECRET` (must_env `INSTANCE_NAME`)) }}",
      "COOKIE_SECRET":       "{{ ssm (printf `/%s/COOKIE_SECRET`      (must_env `INSTANCE_NAME`)) }}",
      "AWS_MCP_REGION":      "{{ ssm (printf `/%s/AWS_MCP_REGION`     (must_env `INSTANCE_NAME`)) }}",
      "TARGET_AWS_REGION":   "{{ ssm (printf `/%s/TARGET_AWS_REGION`  (must_env `INSTANCE_NAME`)) }}",
      "AWS_LWA_INVOKE_MODE": "response_stream",
      "ASSUME_ROLE_ARN":     "{{ ssm (printf `/%s/ASSUME_ROLE_ARN`    (must_env `INSTANCE_NAME`)) }}",
      "STORE_BACKEND":       "dynamodb",
      "DYNAMODB_TABLE":      "{{ ssm (printf `/%s/DYNAMODB_TABLE`     (must_env `INSTANCE_NAME`)) }}",
      "DYNAMODB_REGION":     "{{ ssm (printf `/%s/DYNAMODB_REGION`    (must_env `INSTANCE_NAME`)) }}"
    }
  }
}
