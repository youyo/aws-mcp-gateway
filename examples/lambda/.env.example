# Copy to .env and fill in values
# .env is loaded automatically by mise (_.file = ".env")

# Set after running: mise run setup
# (iam:create prints the ARN to copy here)
ROLE_ARN=arn:aws:iam::<ACCOUNT_ID>:role/amg-lambda-role

# Optional overrides (defaults are in mise.toml)
# INSTANCE_NAME=amg
# AWS_REGION=ap-northeast-1
# VERSION=0.5.2
